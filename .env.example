# ============================================================
# SOCIAL MEDIA AUTOMATION AGENT — Environment Variables
# Copy this file to .env and fill in your actual credentials
# ============================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Google Drive ---
# Path to the service account JSON key file OR use OAuth credentials
GOOGLE_CREDENTIALS_PATH=credentials.json
# The folder ID of your "Portfolio" folder in Google Drive
# Get this from the URL: drive.google.com/drive/folders/<FOLDER_ID>
GOOGLE_PORTFOLIO_FOLDER_ID=your_folder_id_here

# --- Server Public URL (for serving temp images to Instagram/Pinterest API) ---
# Local testing: http://localhost:8000
# Railway deployment: https://your-app-name.up.railway.app
SERVER_BASE_URL=http://localhost:8000

# --- Facebook / Instagram ---
# Facebook Page Access Token (long-lived)
FACEBOOK_PAGE_ACCESS_TOKEN=your_token
FACEBOOK_PAGE_ID=your_page_id
# Instagram Business Account ID (linked to Facebook Page)
INSTAGRAM_ACCOUNT_ID=your_instagram_business_id

# --- Posting Schedule ---
# Time to run the daily check (24h format, server timezone)
SCHEDULE_HOUR=10
SCHEDULE_MINUTE=0
# Minutes gap between each post
POST_INTERVAL_MINUTES=5
# Max posts per day
MAX_POSTS_PER_DAY=3

# --- App ---
APP_ENV=production
SECRET_KEY=change_this_to_a_random_secret_string
DATABASE_PATH=../data/database.db
